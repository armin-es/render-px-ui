{
  "name": "@render-px/ui",
  "version": "0.1.0",
  "description": "Token-based UI components: Button, Badge, Callout, InlineCode",
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "tailwind",
    "cva"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/armin-es/render-px-ui.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
